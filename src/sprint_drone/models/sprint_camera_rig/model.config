<?xml version="1.0"?>
<model>
  <name>sprint_camera_rig</name>
  <version>1.0</version>
  <sdf version="1.10">model.sdf</sdf>
  <description>
    Minimal static camera rig for standalone perception testing.
    Place at (x, y, 2.0) above the grid to test ArUco/grid detection
    without running PX4 SITL.

    In a full PX4 SITL run, the equivalent camera sensor lives inside
    the x500 drone model (see px4_sitl notes in sim_gazebo.launch.py).
  </description>
</model>
